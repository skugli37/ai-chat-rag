// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Conversation {
  id          String     @id @default(cuid())
  title       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  messages    Message[]
  
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String       // 'user', 'assistant', 'system'
  content        String
  tokens         Int          @default(0)
  createdAt      DateTime     @default(now())
  
  // For branching
  parentMessageId String?
  parentMessage   Message?    @relation("MessageBranches", fields: [parentMessageId], references: [id])
  childMessages   Message[]   @relation("MessageBranches")
  
  // For citations
  citations       Citation[]
  
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@index([conversationId])
  @@index([parentMessageId])
  @@map("messages")
}

model Document {
  id          String      @id @default(cuid())
  filename    String
  content     String
  fileType    String      // 'txt', 'md', 'pdf', 'docx', 'image'
  fileSize    Int
  chunkCount  Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  chunks      DocumentChunk[]
  
  @@map("documents")
}

model DocumentChunk {
  id           String   @id @default(cuid())
  documentId   String
  content      String
  chunkIndex   Int
  
  // Real embeddings - stored as JSON array of floats
  embedding    String?  
  
  // For keyword search (BM25 tokens)
  tokens       String?  // JSON array of tokenized words
  
  createdAt    DateTime @default(now())
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  
  @@index([documentId])
  @@map("document_chunks")
}

model Citation {
  id          String   @id @default(cuid())
  messageId   String
  documentId  String
  chunkIndex  Int
  content     String   // The cited text
  score       Float    // Similarity score
  
  createdAt   DateTime @default(now())
  
  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  
  @@index([messageId])
  @@map("citations")
}

model SystemPrompt {
  id          String   @id @default(cuid())
  name        String
  content     String
  isDefault   Boolean  @default(false)
  
  // For few-shot examples
  examples    String?  // JSON array of {input, output} pairs
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("system_prompts")
}

model PromptTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  template    String
  category    String   @default("general") // "general", "coding", "writing", "analysis"
  variables   String?  // JSON array of variable names
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("prompt_templates")
}

model ChatExport {
  id              String   @id @default(cuid())
  conversationId  String
  format          String   // "markdown", "pdf", "json"
  content         String   // The exported content
  filename        String
  
  createdAt       DateTime @default(now())
  
  @@map("chat_exports")
}
